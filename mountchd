#!/bin/bash
# mountchd - extract and mount a .chd (CD image) created by mkchd, then
# cd into it, mirroring mountvhd's convenience. Must be sourced:
#   . mountchd <name.chd>
#
# Unlike a VHD (a raw disk image the kernel can loop-mount directly),
# a CHD is a compressed container -- chdman has to decompress it to a
# real file first. That extracted copy can be as large as the original
# disc (hundreds of MB), so it's kept on /media/fat rather than /tmp:
# /tmp is RAM-backed (tmpfs) with only ~240MB available on this system,
# and a big disc could exhaust it. When you're done, run:
#   . umountchd
# which unmounts and deletes the extracted copy -- these tools should
# always clean up after themselves rather than leave scratch data
# sitting around.

CHDMAN="/media/fat/linux/chdman"
EXTRACT_DIR="/media/fat/linux/.mountchd_extract"
MOUNTPOINT="/media/fat/linux/.mountchd_mount"

CHD="$1"

if [ -z "$CHD" ]; then
    echo "Usage: . mountchd <name.chd>"
    return 1 2>/dev/null || exit 1
fi
if [ ! -f "$CHD" ]; then
    echo "Error: file not found: $CHD"
    return 1 2>/dev/null || exit 1
fi
if [ ! -x "$CHDMAN" ]; then
    echo "Error: chdman not found or not executable at $CHDMAN"
    return 1 2>/dev/null || exit 1
fi
if mount | grep -q " $MOUNTPOINT "; then
    echo "Error: $MOUNTPOINT is already mounted. Run '. umountchd' first."
    return 1 2>/dev/null || exit 1
fi

CHD="$(realpath "$CHD")"

rm -rf "$EXTRACT_DIR"
mkdir -p "$EXTRACT_DIR"

# Confirm this is actually a CD-image CHD (has track metadata) before
# trying extractcd -- a createraw/createhd CHD needs a different
# extraction command and isn't a mountable filesystem the same way.
if ! "$CHDMAN" info -i "$CHD" 2>/dev/null | grep -q "^Metadata:"; then
    echo "Error: $CHD doesn't look like a CD image CHD (no track metadata)."
    echo "mountchd only supports CHDs created by mkchd (createcd)."
    rm -rf "$EXTRACT_DIR"
    return 1 2>/dev/null || exit 1
fi

echo "Extracting $CHD (this can take a while for larger discs)..."
"$CHDMAN" extractcd -i "$CHD" -o "$EXTRACT_DIR/track.cue" -ob "$EXTRACT_DIR/track.bin" 2>&1 | tee /tmp/mountchd_extract.log
EXTRACT_STATUS=${PIPESTATUS[0]}
if [ "$EXTRACT_STATUS" -ne 0 ]; then
    echo "Error: chdman failed to extract $CHD (exit code $EXTRACT_STATUS)"
    rm -rf "$EXTRACT_DIR"
    return 1 2>/dev/null || exit 1
fi

# Figure out the sector format chdman actually wrote, from the .cue
# sheet's own TRACK line. Real CD data tracks are usually raw 2352-byte
# sectors (16-byte sync+header, 2048 bytes of user data, 288 bytes of
# EDC/ECC) which the kernel's iso9660 driver can't mount directly --
# only the 2048-byte user data portion, at a fixed 16-byte offset in
# every sector, is the actual filesystem content.
TRACK_MODE="$(grep -m1 "TRACK" "$EXTRACT_DIR/track.cue" | awk '{print $3}')"

case "$TRACK_MODE" in
    MODE1/2352|MODE2/2352)
        echo "Raw 2352-byte sectors detected; extracting user data..."
        python3 -c "
SECTOR = 2352
OFFSET = 16
LENGTH = 2048
with open('$EXTRACT_DIR/track.bin', 'rb') as fin, open('$EXTRACT_DIR/track.iso', 'wb') as fout:
    while True:
        sector = fin.read(SECTOR)
        if len(sector) < SECTOR:
            break
        fout.write(sector[OFFSET:OFFSET+LENGTH])
"
        rm -f "$EXTRACT_DIR/track.bin"
        ISO_PATH="$EXTRACT_DIR/track.iso"
        ;;
    MODE1/2048)
        mv "$EXTRACT_DIR/track.bin" "$EXTRACT_DIR/track.iso"
        ISO_PATH="$EXTRACT_DIR/track.iso"
        ;;
    *)
        echo "Error: unsupported track mode '$TRACK_MODE' -- only data"
        echo "tracks (MODE1/MODE2) are mountable as a filesystem."
        rm -rf "$EXTRACT_DIR"
        return 1 2>/dev/null || exit 1
        ;;
esac

mkdir -p "$MOUNTPOINT"
if ! mount -o loop,ro "$ISO_PATH" "$MOUNTPOINT"; then
    echo "Error: failed to mount extracted image."
    rmdir "$MOUNTPOINT" 2>/dev/null
    rm -rf "$EXTRACT_DIR"
    return 1 2>/dev/null || exit 1
fi

echo "Mounted $CHD at $MOUNTPOINT"
echo "Run '. umountchd' when done to unmount and clean up."
cd "$MOUNTPOINT"
