#!/bin/bash
# mkima - create a raw floppy disk image (.ima -- the same underlying
# format WinImage produces: a plain FAT12 filesystem with no partition
# table, exactly like a real floppy), optionally injecting files from
# a directory or an archive.
#
# Usage:
#   mkima <name.ima>                      blank formatted floppy (1.44MB default)
#   mkima <name.ima> -s <size>            blank formatted floppy of a given size
#   mkima <name.ima> <source>             formatted floppy + inject <source>'s files
#   mkima <name.ima> <source> -s <size>   same, with an explicit size
#
# <source> can be a directory (its contents are copied directly) or a
# supported archive: .zip, .tar, .tar.gz/.tgz, .tar.bz2/.tbz2
#
# Sizes (-s): 360k, 720k, 1.2m, 1.44m (default), 2.88m -- the five
# standard floppy geometries. If a <source> is given and no -s is
# specified, the smallest standard size that fits the source's actual
# content is chosen automatically.

set -e

DEST_DIR="$(pwd)"
MCOPY="/media/fat/linux/mcopy"

# mtools dispatches its sub-commands based on how it's invoked (its own
# filename), not via a first argument -- so mcopy has to exist as an
# actual symlink to the mtools binary, not just be called directly.
# Created automatically here so dropping in the mtools binary alone is
# enough; no manual setup step required.
if [ ! -e "$MCOPY" ]; then
    ln -sf mtools "$MCOPY" 2>/dev/null
fi
if [ ! -x "$MCOPY" ]; then
    echo "Error: $MCOPY not found or not executable (is mtools installed at /media/fat/linux/mtools?)"
    exit 1
fi

size_to_bytes() {
    case "$1" in
        360k|360K) echo 368640 ;;
        720k|720K) echo 737280 ;;
        1.2m|1.2M) echo 1228800 ;;
        1.44m|1.44M) echo 1474560 ;;
        2.88m|2.88M) echo 2949120 ;;
        *) echo "" ;;
    esac
}

# Same archive handling as mkvhd, for consistency.
extract_archive() {
    local archive="$1"
    local dest="$2"
    case "$archive" in
        *.[Zz][Ii][Pp])
            unzip -o -q "$archive" -d "$dest"
            ;;
        *.[Tt][Aa][Rr].[Gg][Zz]|*.[Tt][Gg][Zz])
            tar -xzf "$archive" -C "$dest"
            ;;
        *.[Tt][Aa][Rr].[Bb][Zz]2|*.[Tt][Bb][Zz]2)
            tar -xjf "$archive" -C "$dest"
            ;;
        *.[Tt][Aa][Rr])
            tar -xf "$archive" -C "$dest"
            ;;
        *)
            echo "Error: unsupported archive type: $archive"
            echo "Supported: .zip, .tar, .tar.gz/.tgz, .tar.bz2/.tbz2"
            return 1
            ;;
    esac
}

# Same wrapper-folder collapsing as mkvhd, in case an archive's real
# content sits inside a redundant top-level folder.
flatten_wrapper_dirs() {
    local dest="$1"
    local cur="$dest"
    local i entries staging
    for i in 1 2 3 4 5; do
        entries=("$cur"/*)
        if [ ! -e "${entries[0]}" ]; then
            break
        fi
        if [ "${#entries[@]}" -eq 1 ] && [ -d "${entries[0]}" ]; then
            cur="${entries[0]}"
        else
            break
        fi
    done
    if [ "$cur" != "$dest" ]; then
        staging="$(mktemp -d)"
        find "$cur" -mindepth 1 -maxdepth 1 -exec mv -t "$staging" {} +
        rm -rf "$dest"
        mv "$staging" "$dest"
    fi
}

# Same accurate uncompressed-size estimate mkvhd uses for its suggested
# size, rather than guessing from the compressed size.
archive_uncompressed_size() {
    local archive="$1"
    local bytes
    case "$archive" in
        *.[Zz][Ii][Pp])
            bytes="$(unzip -l "$archive" | tail -1 | awk '{print $1}')"
            ;;
        *.[Tt][Aa][Rr].[Gg][Zz]|*.[Tt][Gg][Zz])
            bytes="$(tar -tzvf "$archive" | awk '{sum+=$3} END{print sum+0}')"
            ;;
        *.[Tt][Aa][Rr].[Bb][Zz]2|*.[Tt][Bb][Zz]2)
            bytes="$(tar -tjvf "$archive" | awk '{sum+=$3} END{print sum+0}')"
            ;;
        *.[Tt][Aa][Rr])
            bytes="$(tar -tvf "$archive" | awk '{sum+=$3} END{print sum+0}')"
            ;;
        *)
            bytes=0
            ;;
    esac
    if ! echo "$bytes" | grep -Eq '^[0-9]+$'; then
        bytes=0
    fi
    printf '%s' "$bytes"
}

if [ -z "$1" ]; then
    echo "Usage:"
    echo "  mkima <name.ima>                      blank formatted floppy (1.44MB default)"
    echo "  mkima <name.ima> -s <size>            blank formatted floppy of a given size"
    echo "  mkima <name.ima> <source>              inject a directory or archive"
    echo "  mkima <name.ima> <source> -s <size>    same, with an explicit size"
    echo
    echo "Sizes: 360k, 720k, 1.2m, 1.44m (default), 2.88m"
    exit 1
fi

OUTNAME=""
SOURCE=""
SIZE_SPEC=""

while [ $# -gt 0 ]; do
    case "$1" in
        -s)
            SIZE_SPEC="$2"
            shift 2
            ;;
        *)
            if [ -z "$OUTNAME" ]; then
                OUTNAME="$1"
            elif [ -z "$SOURCE" ]; then
                SOURCE="$1"
            else
                echo "Error: unexpected argument: $1"
                exit 1
            fi
            shift
            ;;
    esac
done

case "$OUTNAME" in
    *.[Ii][Mm][Aa]|*.[Ii][Mm][Gg]) ;;
    *) OUTNAME="${OUTNAME}.ima" ;;
esac
OUTPATH="$DEST_DIR/$OUTNAME"

if [ -e "$OUTPATH" ]; then
    echo "Error: $OUTPATH already exists."
    exit 1
fi

if [ -n "$SOURCE" ] && [ ! -e "$SOURCE" ]; then
    echo "Error: source not found: $SOURCE"
    exit 1
fi

if [ -n "$SIZE_SPEC" ]; then
    SIZE_BYTES="$(size_to_bytes "$SIZE_SPEC")"
    if [ -z "$SIZE_BYTES" ]; then
        echo "Error: unsupported size '$SIZE_SPEC'."
        echo "Supported: 360k, 720k, 1.2m, 1.44m, 2.88m"
        exit 1
    fi
elif [ -n "$SOURCE" ]; then
    if [ -d "$SOURCE" ]; then
        SOURCE_BYTES="$(du -sb "$SOURCE" | awk '{print $1}')"
    else
        SOURCE_BYTES="$(archive_uncompressed_size "$SOURCE")"
    fi
    SIZE_BYTES=""
    for candidate in 368640 737280 1228800 1474560 2949120; do
        # ~5% headroom for filesystem overhead (FAT tables, root dir).
        if [ "$SOURCE_BYTES" -le $((candidate * 95 / 100)) ]; then
            SIZE_BYTES="$candidate"
            break
        fi
    done
    if [ -z "$SIZE_BYTES" ]; then
        echo "Error: source ($SOURCE_BYTES bytes) is too large for any"
        echo "standard floppy size (max 2.88MB / 2,949,120 bytes)."
        exit 1
    fi
else
    SIZE_BYTES=1474560
fi

echo "Creating $((SIZE_BYTES / 1024))KB floppy image..."
truncate -s "$SIZE_BYTES" "$OUTPATH"
mkfs.vfat -I "$OUTPATH" >/dev/null

if [ -n "$SOURCE" ]; then
    # Written onto the image via mtools (mcopy) rather than a loop
    # device + kernel mount -- mtools operates on the image file
    # directly, so this needs no root privileges at all. Archives
    # still get extracted to a normal local staging directory first
    # (extract_archive/flatten_wrapper_dirs are unchanged, since they
    # just work on regular files either way); only the final "install
    # onto the image" step changed.
    COPY_OK=1
    STAGE_DIR="$SOURCE"
    STAGE_IS_TEMP=0
    if [ ! -d "$SOURCE" ]; then
        STAGE_DIR="$(mktemp -d)"
        STAGE_IS_TEMP=1
        extract_archive "$SOURCE" "$STAGE_DIR" || COPY_OK=0
        flatten_wrapper_dirs "$STAGE_DIR"
    fi

    if [ "$COPY_OK" -eq 1 ]; then
        shopt -s dotglob nullglob
        STAGE_ITEMS=("$STAGE_DIR"/*)
        shopt -u dotglob nullglob
        if [ "${#STAGE_ITEMS[@]}" -gt 0 ]; then
            "$MCOPY" -s -D o -D O -i "$OUTPATH" "${STAGE_ITEMS[@]}" :: || COPY_OK=0
        fi
    fi

    if [ "$STAGE_IS_TEMP" -eq 1 ]; then
        rm -rf "$STAGE_DIR"
    fi

    if [ "$COPY_OK" -eq 0 ]; then
        echo "Error: failed to copy $SOURCE onto the floppy image (likely too large)."
        rm -f "$OUTPATH"
        exit 1
    fi
fi

echo "Done: $OUTPATH"
