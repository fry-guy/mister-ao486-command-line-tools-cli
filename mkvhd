        # Unix-made zip's ordinary rw-rw-rw- files came out tagged
        # Hidden+System, making every injected file invisible in
        # Windows' own File Manager. Only trust this field when the
        # zip actually came from an MS-DOS/FAT host.
        continue
    attr = (info.external_attr >> 16) & 0xFF
    if attr & 0x07:
        rel = info.filename
        if prefix and rel.startswith(prefix + '/'):
            rel = rel[len(prefix)+1:]
        print(f'{rel} {attr}')
" > "$ARCHIVE_ATTR_MANIFEST" 2>/dev/null
                ;;
        esac

        # See loop_copy_in's own comment: mtools was found to silently
        # drop files/subdirectories on large, real archives, so this
        # goes through the kernel's own loop-mount + cp instead.
        if ! loop_copy_in "$OUTPATH" $((128 * 512)) "$GAME_NAME" "$STAGE_DIR/$GAME_NAME/."; then
            echo "Error: failed to copy $ARCHIVE onto the VHD."
            [ -n "$ARCHIVE_ATTR_MANIFEST" ] && rm -f "$ARCHIVE_ATTR_MANIFEST"
            exit 1
        fi

        if [ -n "$ARCHIVE_ATTR_MANIFEST" ] && [ -s "$ARCHIVE_ATTR_MANIFEST" ]; then
            while read -r FNAME FATTR; do
                [ -z "$FNAME" ] && continue
                MATTRIB_FLAGS=()
                [ $((FATTR & 1)) -ne 0 ] && MATTRIB_FLAGS+=("+r")
                [ $((FATTR & 2)) -ne 0 ] && MATTRIB_FLAGS+=("+h")
                [ $((FATTR & 4)) -ne 0 ] && MATTRIB_FLAGS+=("+s")
                if [ "${#MATTRIB_FLAGS[@]}" -gt 0 ]; then
                    "$MATTRIB" "${MATTRIB_FLAGS[@]}" -i "$OUTPATH@@$((128 * 512))" "::$GAME_NAME/$FNAME" 2>/dev/null
                fi
            done < "$ARCHIVE_ATTR_MANIFEST"
        fi
        [ -n "$ARCHIVE_ATTR_MANIFEST" ] && rm -f "$ARCHIVE_ATTR_MANIFEST"

        AUTOEXEC_TMP="$(mktemp)"
        "$MCOPY" -n -i "$OUTPATH@@$((128 * 512))" ::AUTOEXEC.BAT "$AUTOEXEC_TMP"
        printf 'CD %s\r\n' "$GAME_NAME" >> "$AUTOEXEC_TMP"
        if [ -n "$LAUNCH_SUBDIR" ]; then
            printf 'CD %s\r\n' "$LAUNCH_SUBDIR" >> "$AUTOEXEC_TMP"
        fi
        if [ -n "$LAUNCH_EXE" ]; then
            printf '%s\r\n' "$LAUNCH_EXE" >> "$AUTOEXEC_TMP"
        fi
        "$MCOPY" -D o -D O -i "$OUTPATH@@$((128 * 512))" "$AUTOEXEC_TMP" ::AUTOEXEC.BAT

        rm -rf "$STAGE_DIR" "$AUTOEXEC_TMP"
        echo "Game files extracted to \\$GAME_NAME"
        echo "AUTOEXEC.BAT updated with: CD $GAME_NAME"
        if [ -n "$LAUNCH_SUBDIR" ]; then
            echo "                           CD $LAUNCH_SUBDIR"
        fi
        if [ -n "$LAUNCH_EXE" ]; then
            echo "                           $LAUNCH_EXE"
        fi

        echo
        echo "Source archive that can now be removed:"
        echo "  $ARCHIVE"
        read -p "Delete the original source archive? [y/N]: " answer
        if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
            rm -f "$ARCHIVE"
            echo "Deleted."
        else
            echo "Keeping source archive."
        fi
    fi

    echo "======================================================="
    echo " Mount: . mountvhd $OUTPATH"
    echo "======================================================="
else
    echo "[!] Setup may have failed. Try: . mountvhd $OUTPATH"
fi
