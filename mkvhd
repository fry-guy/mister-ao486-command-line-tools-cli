        e = data[i*32:(i+1)*32]
        if e[0] == 0x00:
            break
        if e[0] == 0xE5:
            continue
        attr = e[11]
        if attr == 0x0F or (attr & 0x10):
            continue
        if attr & 0x07:
            name = e[0:8].decode('ascii', errors='replace').strip()
            ext = e[8:11].decode('ascii', errors='replace').strip()
            fname = f'{name}.{ext}' if ext else name
            print(f'{fname} {attr}')
